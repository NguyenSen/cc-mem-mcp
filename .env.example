# ---- Storage (Qdrant) ----
# Leave QDRANT_URL empty to use the embedded, local-file Qdrant (zero setup).
# Set it to point at a shared Qdrant server (e.g. one on your caohoc box).
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
QDRANT_PATH=/data/qdrant
COLLECTION_NAME=cc_memory

# ---- Embedding ----
# EMBEDDING_PROVIDER: local (FastEmbed, no API key) | openai
EMBEDDING_PROVIDER=local
# local default: BAAI/bge-small-en-v1.5   |  openai default: text-embedding-3-small
# EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=
#
# Instruction prefixes — required by the e5 family, harmless (leave empty) otherwise.
# Measured best multilingual setup (see eval/): e5-large lifts real-query recall@5
# from ~0.85 to ~0.92. Switching models changes the vector dim, so use a fresh
# COLLECTION_NAME and re-ingest.
# EMBEDDING_MODEL=intfloat/multilingual-e5-large
# The trailing space matters — keep the quotes so it is preserved.
# EMBEDDING_QUERY_PREFIX="query: "
# EMBEDDING_PASSAGE_PREFIX="passage: "

# ---- Categories (optional) ----
# JSON object {domain: [sub, ...]}. Omit to use the built-in CODE/BUSINESS taxonomy.
# CC_MEM_CATEGORIES={"code":["rules","workflow","os","connections","files","issues"],"business":["goal","decision","constraint","state"]}
# Set to 1 to reject stores whose category is not in the taxonomy (default: warn only).
CC_MEM_STRICT_CATEGORIES=0
